{
  "rules": {
    "keys": {
      ".read": "auth != null && auth.token.email == 'abc@cde.com'",
      "$keyId": {
        ".read": "auth != null && (auth.token.email == 'abc@cde.com' || auth.uid == root.child('keys').child($keyId).child('uid').val() || !root.child('keys').child($keyId).child('uid').exists())",
        ".write": "auth != null && auth.token.email == 'abc@cde.com'",
        "uid": {
          ".write": "auth != null && !data.exists()"
        },
        "lastLoginAt": {
          ".write": "auth != null && (!root.child('keys').child($keyId).child('uid').exists() || root.child('keys').child($keyId).child('uid').val() == auth.uid)"
        },
        "lastLoginIp": {
          ".write": "auth != null && (!root.child('keys').child($keyId).child('uid').exists() || root.child('keys').child($keyId).child('uid').val() == auth.uid)"
        }
      }
    },
    "chats": {
      "$keyId": {
        ".read": "auth != null && (auth.uid == root.child('keys').child($keyId).child('uid').val() || auth.token.email == 'abc@cde.com')",
        ".write": "auth != null && (auth.uid == root.child('keys').child($keyId).child('uid').val() || auth.token.email == 'abc@cde.com')"
      }
    }
  }
}
