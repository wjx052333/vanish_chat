{
  "rules": {
    "keys": {
      ".read": "auth != null && auth.token.email == 'abc@cde.com'",
      "$keyId": {
        ".read": "auth != null",
        ".write": "auth != null && auth.token.email == 'abc@cde.com'",
        "uid": {
          ".write": "auth != null && !data.exists()"
        },
        "lastLoginAt": {
          ".write": "auth != null"
        },
        "lastLoginIp": {
          ".write": "auth != null"
        }
      }
    },
    "chats": {
      "$keyId": {
        ".read": "auth != null",
        ".write": "auth != null"
      }
    }
  }
}
